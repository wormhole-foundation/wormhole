# Build & test the Wormhole Global Accountant Solana program.
#
# The program is loaded by mollusk-svm in integration tests, so the SBF
# binary must exist before `cargo test` runs.

# Exported into every recipe so `cargo test` finds the freshly-built `.so`.
export SBF_OUT_DIR := justfile_directory() / "target/deploy"

# Default recipe: list available targets with their docstrings.
default:
    @just --list

# One build target. The historical dev/prod split existed to gate the
# `test-only-open-digest` feature on/off; with `open_digest` removed
# entirely (canonical digest record now emitted via `sol_log_data`), there
# is no longer any dev-vs-prod feature difference.

[doc("SBF build of the production-shape .so.")]
build:
    cargo build-sbf --features bpf-entrypoint

[doc("Alias preserved for backwards-compatibility with existing scripts.")]
build-prod: build

# The mollusk suite CPIs into the real `solana_noreplay.so` replay-protection
# bitmap program. The canonical `.so` is hash-pinned under
# `programs/global-accountant/tests/fixtures/`. The mollusk test harness
# verifies its SHA-256 against a hard-coded constant in
# `tests/common/mollusk_fixtures.rs` before loading; drift panics with the
# recompute-and-update recipe inline in the failure message.
#
# To intentionally regenerate a fixture:
#   1. Build the upstream program (cd <sibling-repo> && cargo build-sbf).
#   2. Copy the resulting .so over tests/fixtures/<name>.so.
#   3. Recompute the digest:
#        shasum -a 256 programs/global-accountant/tests/fixtures/<name>.so
#   4. Update the corresponding *_SO_SHA256 constant in mollusk_fixtures.rs.
#   5. Commit both the .so and the const update in the same change.
#
# For local iteration without rebaking the fixture, point an env override at
# your locally-built .so:
#   GA_NOREPLAY_SO=/path/to/solana_noreplay.so cargo test ...
# The override skips the SHA-256 check (active-development escape hatch).

[doc("Mollusk integration tests.")]
test: build
    cargo test

# SBF-target type-check. There is no upstream `cargo check-sbf`, but
# `cargo build-sbf` registers the platform-tools compiler with rustup (e.g.
# `1.89.0-sbpf-solana-v1.52`), which can drive a plain `cargo check` against
# the real `sbpf-solana-solana` target. This checks the exact cfg shape that
# ships (`target_os = "solana"` arms, real syscall declarations) without the
# cost of a full `build-sbf`. The toolchain name embeds the platform-tools
# version, so it is discovered rather than hard-coded.
#
# Note: clippy cannot run on this toolchain (Anza ships no cargo-clippy for
# platform-tools, and rustup cannot add components to custom toolchains).
# RUSTFLAGS=-Dwarnings promotes the compiler's own lints to errors on the SBF
# target; `clippy-sbf` below approximates clippy coverage of the SBF arms.

[doc("Type-check against the real SBF target (sbpf-solana-solana), warnings denied.")]
check:
    #!/usr/bin/env bash
    set -euo pipefail
    toolchain=$(rustup toolchain list | awk '/sbpf-solana/ {print $1; exit}')
    if [ -z "${toolchain}" ]; then
        echo "ERROR: no sbpf-solana platform-tools toolchain found in rustup." >&2
        echo "Run 'cargo build-sbf' once to install it." >&2
        exit 1
    fi
    echo "Using toolchain: ${toolchain}"
    export RUSTFLAGS="-Dwarnings"
    cargo "+${toolchain}" check --locked --target sbpf-solana-solana \
        -p global-accountant --features bpf-entrypoint

# SBF-arm clippy. The platform-tools toolchain ships no clippy, but upstream
# nightly clippy knows the tier-3 `bpfel-unknown-none` target, which sets
# `target_arch = "bpf"` — the second arm of the crate's cfg pattern
# (`any(target_os = "solana", target_arch = "bpf")`), kept precisely so this
# recipe can lint the SBF-shaped code (syscalls, entrypoint, no_std). Tier 3
# ships no prebuilt core/alloc, hence nightly + rust-src + `-Zbuild-std`.
#
# Caveats, recorded so nobody is surprised later:
#   * Approximation: code gated *exclusively* on `target_os = "solana"` is
#     invisible here. The crate's convention is the `any(...)` pattern, which
#     keeps coverage effectively total — maintain that convention.
#   * Nightly: clippy lint names drift (e.g. workspace lint tables may emit
#     `renamed_and_removed_lints` warnings). Supplementary gate only; the
#     stable host `clippy` target remains authoritative.

[doc("Nightly clippy of the SBF-shaped code via bpfel-unknown-none.")]
clippy-sbf:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! cargo +nightly clippy --version >/dev/null 2>&1; then
        echo "ERROR: nightly clippy not available." >&2
        echo "Run 'rustup component add clippy --toolchain nightly'." >&2
        exit 1
    fi
    if ! rustup component list --toolchain nightly --installed 2>/dev/null | grep -q rust-src; then
        echo "ERROR: rust-src not installed for nightly (required by -Zbuild-std)." >&2
        echo "Run 'rustup component add rust-src --toolchain nightly'." >&2
        exit 1
    fi
    cargo +nightly clippy --locked -Zbuild-std=core,alloc --target bpfel-unknown-none \
        -p global-accountant -p global-accountant-definitions \
        --features bpf-entrypoint -- -D warnings

[doc("Clippy against the host build.")]
clippy:
    cargo clippy --all-targets -- -D warnings

[doc("cargo clean.")]
clean:
    cargo clean
